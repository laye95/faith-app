{
  "name": "faith-app",
  "main": "expo-router/entry",
  "version": "0.5.1",
  "scripts": {
    "eas-build-pre-install": "npm run version:sync",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build:ios": "eas build --platform ios --profile testflight --auto-submit",
    "build:android": "eas build --platform android --profile preview",
    "build:preview": "eas build --platform all --profile preview",
    "build:testflight": "eas build --platform ios --profile testflight --auto-submit",
    "version:sync": "node -e \"const a=require('./app.json'); const v=a.expo.version; const p=require('./package.json'); p.version=v; require('fs').writeFileSync('package.json', JSON.stringify(p,null,2)); require('fs').writeFileSync('VERSION.md', v);\"",
    "version:sync-to-app": "node -e \"const p=require('./package.json'); const v=p.version; const a=require('./app.json'); a.expo.version=v; require('fs').writeFileSync('app.json', JSON.stringify(a,null,2)); require('fs').writeFileSync('VERSION.md', v);\"",
    "version:bump:patch": "npm version patch --no-git-tag-version && npm run version:sync-to-app",
    "version:bump:minor": "npm version minor --no-git-tag-version && npm run version:sync-to-app",
    "version:bump:major": "npm version major --no-git-tag-version && npm run version:sync-to-app"
  },
  "dependencies": {
    "@expo/html-elements": "^0.10.1",
    "@expo/vector-icons": "^15.0.3",
    "@gluestack-ui/core": "^3.0.12",
    "@gluestack-ui/utils": "^3.0.15",
    "@legendapp/motion": "^2.5.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/drawer": "^7.5.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/query-persist-client-core": "^5.91.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "^8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.4",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-video": "^3.0.16",
    "expo-web-browser": "~15.0.10",
    "i18n-js": "^4.5.2",
    "lottie-react-native": "~7.3.1",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-aria": "^3.46.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-color-matrix-image-filters": "^8.0.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.5.1",
    "react-stately": "^3.44.0",
    "storyblok": "^4.15.0",
    "tailwind-variants": "^0.1.20"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
